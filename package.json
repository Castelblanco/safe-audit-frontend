{
    "name": "safe-audit-frontend",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite --host --mode dev",
        "build": "run-p type-check \"build-only {@}\" --",
        "preview": "vite preview",
        "build-only": "vite build",
        "type-check": "vue-tsc --build",
        "lint": "biome lint ./src",
        "format:check": "biome check ./src",
        "format:write": "biome format --write ./src"
    },
    "dependencies": {
        "@lucide/vue": "1.9.0",
        "@quasar/extras": "1.18.0",
        "@tailwindcss/vite": "4.2.4",
        "axios": "1.15.1",
        "luxon": "3.7.2",
        "pinia": "3.0.4",
        "qs": "6.15.1",
        "quasar": "2.19.3",
        "tailwindcss": "4.2.4",
        "vue": "3.5.32",
        "vue-router": "5.0.4"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.12",
        "@quasar/vite-plugin": "1.11.0",
        "@tsconfig/node24": "24.0.4",
        "@types/luxon": "3.7.1",
        "@types/node": "24.12.2",
        "@types/qs": "6.15.0",
        "@vitejs/plugin-vue": "6.0.6",
        "@vitejs/plugin-vue-jsx": "5.1.5",
        "@vue/tsconfig": "0.9.1",
        "autoprefixer": "10.5.0",
        "jiti": "2.6.1",
        "npm-run-all2": "8.0.4",
        "sass-embedded": "1.99.0",
        "typescript": "~6.0.0",
        "vite": "8.0.8",
        "vite-plugin-vue-devtools": "8.1.1",
        "vite-tsconfig-paths": "6.1.1",
        "vue-tsc": "3.2.6"
    }
}
